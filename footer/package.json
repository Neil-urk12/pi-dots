{
  "name": "@neilurk12/pi-clean-footer",
  "version": "0.4.3",
  "description": "Clean, minimal, and lightweight powerline-style footer extension for pi coding agent.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "footer",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neil-urk12/pi-dots.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "example.png"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:check": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write \"src/**/*.ts\"",
    "format:check": "oxfmt --check \"src/**/*.ts\""
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
