{
  "name": "@neilurk12/pi-clean-footer",
  "version": "0.2.5",
  "description": "Clean, minimal, and lightweight powerline-style footer extension for pi coding agent.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "footer",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neil-urk12/pi-dots.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "example.png"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
