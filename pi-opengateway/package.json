{
  "name": "@neilurk12/pi-opengateway",
  "version": "1.0.0",
  "description": "pi extension — OpenGateway provider (OpenAI-compatible)",
  "type": "module",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "opengateway",
    "openai",
    "provider",
    "gateway"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neil-urk12/pi-dots.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "config.example.json",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
