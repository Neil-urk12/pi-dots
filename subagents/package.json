{
  "name": "neilurk12/pi-subagents",
  "version": "0.0.1",
  "description": "Minimal subagents extension for pi coding agent — delegate tasks to scout, researcher, and worker agents with single and parallel execution.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "subagents",
    "agent"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup && rm -rf dist/agents dist/tools && cp -r agents dist/agents && cp -r tools dist/tools",
    "dev": "tsup --watch",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "typebox": "*"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@mariozechner/pi-tui": "^0.73.1",
    "@types/node": "^25.6.2",
    "oxlint": "^1.63.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
